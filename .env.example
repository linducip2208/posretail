APP_NAME="POS Retail"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://posretail.test

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_retail
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=posretail.test,localhost:8000,localhost

CORS_ALLOWED_ORIGINS=*

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@posretail.test"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Payment Gateway — Dynamic Provider
# POS Retail menggunakan sistem provider dinamis (multi-provider).
# User dapat menambahkan provider payment gateway sendiri dari admin UI.
# Provider dikonfigurasi via admin panel: /admin (Sistem > Payment Providers)
# Format API didukung: Redirect-based, Direct API, QR-based
# ---------------------------------------------------------------------------
# Contoh konfigurasi manual (opsional, override dari admin UI):
# PAYMENT_PROVIDER_1_NAME="Midtrans"
# PAYMENT_PROVIDER_1_MODE=sandbox
# PAYMENT_PROVIDER_1_SERVER_KEY=
# PAYMENT_PROVIDER_1_CLIENT_KEY=
# PAYMENT_PROVIDER_1_MERCHANT_ID=
# PAYMENT_PROVIDER_1_SANDBOX_URL=https://api.sandbox.midtrans.com
# PAYMENT_PROVIDER_1_PRODUCTION_URL=https://api.midtrans.com
#
# PAYMENT_PROVIDER_2_NAME="Xendit"
# PAYMENT_PROVIDER_2_API_KEY=
# PAYMENT_PROVIDER_2_CALLBACK_TOKEN=

# ---------------------------------------------------------------------------
# Notification Providers — Dynamic Provider
# Provider notifikasi (WhatsApp, Email, SMS) dikonfigurasi via admin UI.
# ---------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# License v3 Pairing (whitelabel.co.id)
# ---------------------------------------------------------------------------
LICENSE_SERVER_URL=https://whitelabel.co.id
LICENSE_DEV_BYPASS=true
LICENSE_HEARTBEAT_INTERVAL=86400
LICENSE_HEARTBEAT_GRACE=604800
